generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  owner
  admin
  editor
  viewer
}

enum PagePublicationStatus {
  draft
  published
  suspended
}

enum SubscriptionStatus {
  trial
  active
  past_due
  canceled
  paused
  suspended
}

enum BillingProviderKind {
  mock
  mercadopago
  asaas
}

enum DomainType {
  subdomain
  custom
}

enum DomainStatus {
  pending
  verified
  active
  disabled
}

model User {
  id                        String         @id @default(cuid())
  firebaseUid               String         @unique
  email                     String         @unique
  name                      String?
  avatarUrl                 String?
  isSuperAdmin              Boolean        @default(false)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  memberships               Membership[]
  ownedWorkspaces           Workspace[]    @relation("WorkspaceOwner")
  uploadedAssets            Asset[]        @relation("AssetUploader")
  publishedVersions         PageVersion[]  @relation("VersionPublisher")
  auditLogs                 AuditLog[]     @relation("AuditActor")
  adminUpdatedSubscriptions Subscription[] @relation("SubscriptionAdminUser")
}

model Workspace {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  ownerId       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships   Membership[]
  landingPages  LandingPage[]
  assets        Asset[]
  leads         Lead[]
  subscriptions Subscription[]
  domains       Domain[]
  auditLogs     AuditLog[]
  PageVersion   PageVersion[]

  @@index([ownerId])
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(owner)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model LandingPage {
  id                 String                @id @default(cuid())
  workspaceId        String
  name               String
  slug               String
  siteSubdomain      String?
  seoTitle           String
  seoDescription     String
  ogImageUrl         String?
  faviconUrl         String?
  ogImageAssetId     String?
  faviconAssetId     String?
  draftContent       Json
  publishedVersionId String?               @unique
  status             PagePublicationStatus @default(draft)
  createdById        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  workspace          Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions           PageVersion[]         @relation("LandingPageVersions")
  publishedVersion   PageVersion?          @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  leads              Lead[]
  domains            Domain[]
  ogImageAsset       Asset?                @relation("OgImageAsset", fields: [ogImageAssetId], references: [id], onDelete: SetNull)
  faviconAsset       Asset?                @relation("FaviconAsset", fields: [faviconAssetId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([siteSubdomain])
}

model PageVersion {
  id               String       @id @default(cuid())
  workspaceId      String
  landingPageId    String
  version          Int
  content          Json
  publishedById    String?
  publishedAt      DateTime     @default(now())
  isRollback       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  landingPage      LandingPage  @relation("LandingPageVersions", fields: [landingPageId], references: [id], onDelete: Cascade)
  publishedBy      User?        @relation("VersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedForPage LandingPage? @relation("PublishedVersion")

  @@unique([landingPageId, version])
  @@index([workspaceId, publishedAt])
}

model Asset {
  id           String        @id @default(cuid())
  workspaceId  String
  uploadedById String
  bucket       String
  key          String
  url          String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  createdAt    DateTime      @default(now())
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy   User          @relation("AssetUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  ogPages      LandingPage[] @relation("OgImageAsset")
  faviconPages LandingPage[] @relation("FaviconAsset")

  @@index([workspaceId, createdAt])
}

model Lead {
  id            String      @id @default(cuid())
  workspaceId   String
  landingPageId String
  name          String
  email         String
  phone         String?
  company       String?
  message       String?
  payload       Json?
  sourceUrl     String?
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime    @default(now())
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([landingPageId, createdAt])
}

model Subscription {
  id                     String              @id @default(cuid())
  workspaceId            String              @unique
  provider               BillingProviderKind @default(mock)
  providerSubscriptionId String?             @unique
  status                 SubscriptionStatus  @default(trial)
  planCode               String              @default("starter")
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialEndsAt            DateTime?
  canceledAt             DateTime?
  pausedAt               DateTime?
  metadata               Json?
  updatedByAdminId       String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  workspace              Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedByAdmin         User?               @relation("SubscriptionAdminUser", fields: [updatedByAdminId], references: [id], onDelete: SetNull)

  @@index([status])
}

model Domain {
  id                String       @id @default(cuid())
  workspaceId       String
  landingPageId     String?
  host              String       @unique
  type              DomainType   @default(subdomain)
  status            DomainStatus @default(pending)
  isPrimary         Boolean      @default(false)
  verificationToken String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  workspace         Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  landingPage       LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([landingPageId])
}

model AuditLog {
  id          String     @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor       User?      @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorId, createdAt])
}
